        },
        {
          "vcmId": "53ee2ec408768310VgnVCM2000002a0c10acRCRD",
          "title": "בלי נשימה",
          "url": "https://www.mako.co.il/mako-vod-keshet/parliament-s1/shorts/Video-53ee2ec40876831006.htm",
          "duration": "04:14",
          "season": 1,
          "lines": []
        },
        {
          "vcmId": "63974b7c124b8310VgnVCM2000002a0c10acRCRD",
          "title": "הקטור המלך",
          "url": "https://www.mako.co.il/mako-vod-keshet/parliament-s1/shorts/Video-63974b7c124b831006.htm",
          "duration": "03:38",
          "season": 1,
          "lines": [
            {
              "t": 5.0,
              "text": "מי מי מי מי מי מי מי מי"
            },
            {
              "t": 9.0,
              "text": "מי במוז'"
            },
            {
              "t": 11.0,
              "text": "מי במוז'"
            },
            {
              "t": 13.0,
              "text": "אמציה, תן לי רה"
            },
            {
              "t": 14.0,
              "text": "רה"
            },
            {
              "t": 15.0,
              "text": "רה"
            },
            {
              "t": 15.0,
              "text": "רה במוז'"
            },
            {
              "t": 17.0,
              "text": "רה במוז'"
            },
            {
              "t": 18.0,
              "text": "רה במוז'"
            },
            {
              "t": 20.0,
              "text": "תגיד לי, אפשר להתחיל או שזה ייקח עוד הרבה זמן?"
            },
            {
              "t": 24.0,
              "text": "סליחה מר אבי שאני טנור ואני צריך לחמם את הגרון שלי"
            },
            {
              "t": 27.0,
              "text": "שלא ייפצע לי עינבל, אני מתנצל"
            },
            {
              "t": 28.0,
              "text": "בסדר, חיממת את כל החדר, בוא נקליט, נו?"
            },
            {
              "t": 31.0,
              "text": "בסדר, אני גם לא רואה שהאידיוט ההוא מוכן"
            },
            {
              "t": 33.0,
              "text": "הנה אני מוכן"
            },
            {
              "t": 34.0,
              "text": "לא אתה האידיוט, זה מאחורי הזכוכית"
            },
            {
              "t": 37.0,
              "text": "זה שאומר \"לא לשפוך לי קפה על הקונסולה\""
            },
            {
              "t": 40.0,
              "text": "\"מי שפך לי קפה הקונסולה?\""
            },
            {
              "t": 42.0,
              "text": "\"שפכת לי קפה על הקונסולה?\""
            },
            {
              "t": 43.0,
              "text": "הוא שומע אותך שאולי"
            },
            {
              "t": 45.0,
              "text": "הוא לא שומע אותי"
            },
            {
              "t": 45.0,
              "text": "אמציה יש פה זכוכית משוריינת"
            },
            {
              "t": 47.0,
              "text": "אז אני אומר לך שהוא שומע אותך"
            },
            {
              "t": 48.0,
              "text": "הוא לא שומע, זה הכל אקוסטי פה"
            },
            {
              "t": 49.0,
              "text": "והוא לא שומע,"
            },
            {
              "t": 50.0,
              "text": "הוא שומע"
            },
            {
              "t": 51.0,
              "text": "חברה, אני אגיד לכם בדיוק אם הוא שומע או לא שומע"
            },
            {
              "t": 54.0,
              "text": "איזה אחד אומר לחבר שלו"
            },
            {
              "t": 57.0,
              "text": "תשמע, ראיתי אישתך  מתפרפרת עם כל העיר"
            },
            {
              "t": 60.0,
              "text": "אז החבר עונה לו פתח תקווה"
            },
            {
              "t": 62.0,
              "text": "גם כן, עיר"
            },
            {
              "t": 63.0,
              "text": "הוא לא שומע"
            },
            {
              "t": 66.0,
              "text": "נו, ברור"
            },
            {
              "t": 67.0,
              "text": "אחרת הוא היה יודע שאני חייב לאמא שלו"
            },
            {
              "t": 68.0,
              "text": "ארבעים שקלים על אתמול בלילה"
            },
            {
              "t": 70.0,
              "text": "שפכתי לה קפה על הקונסולה"
            },
            {
              "t": 72.0,
              "text": "בואו נתחיל, אפשר להתחיל?"
            },
            {
              "t": 76.0,
              "text": "אני מוכן"
            },
            {
              "t": 77.0,
              "text": "אפשר להתחיל?"
            },
            {
              "t": 78.0,
              "text": "אפשר"
            },
            {
              "t": 91.0,
              "text": "בואו ונשמח עם הקטור"
            },
            {
              "t": 94.0,
              "text": "ונציין יום הולדת"
            },
            {
              "t": 97.0,
              "text": "הרופא הפרטי שלנו"
            },
            {
              "t": 99.0,
              "text": "שהוא חבר אמיתי"
            },
            {
              "t": 102.0,
              "text": "נולד לו בבואנוס איירס, משם עלה לחדרה"
            },
            {
              "t": 109.0,
              "text": "ואז עברו לרחובות ואז לחולון"
            },
            {
              "t": 115.0,
              "text": "כל יום שישי הוא מתקשר, שבת שלום ואז חופר"
            },
            {
              "t": 121.0,
              "text": "זה הקטור המלך"
            },
            {
              "t": 128.0,
              "text": "הקטור המלך הוא לי חבר, הוא לי חידה"
            },
            {
              "t": 133.0,
              "text": "הקטור המלך, תמיד מסמר המסיבה"
            },
            {
              "t": 138.0,
              "text": "אז אתה מסמר"
            },
            {
              "t": 140.0,
              "text": "הקטור שלנו, אנחנו אוהבים אותך"
            },
            {
              "t": 145.0,
              "text": "הקטור שלנו, בן חמישים וארבעה"
            },
            {
              "t": 154.0,
              "text": "כל בוקר הוא קם בשבע, שבע ורבע"
            },
            {
              "t": 161.0,
              "text": "שמונה ורבע הוא כבר, בבית החולים"
            },
            {
              "t": 166.0,
              "text": "פעם בשבוע מת לו, חולה בריא בין הידיים"
            },
            {
              "t": 172.0,
              "text": "אך הוא תמיד ישמור, על חיוך וקריצה"
            },
            {
              "t": 179.0,
              "text": "אוהב עוגות בטעם תות, ליד כרמלה הוא סמרטוט"
            },
            {
              "t": 184.0,
              "text": "זה הקטור המלך"
            },
            {
              "t": 190.0,
              "text": "הקטור המלך, הוא לי חבר הוא לי חידה"
            },
            {
              "t": 196.0,
              "text": "הוא לי חבר הוא לי חידה"
            },
            {
              "t": 197.0,
              "text": "הקטור המלך, תמיד מסמר המסיבה"
            },
            {
              "t": 201.0,
              "text": "הוא לי חבר הוא לי חידה"
            },
            {
              "t": 203.0,
              "text": "הקטור שלנו, אנחנו אוהבים אותך"
            },
            {
              "t": 208.0,
              "text": "הקטור שלנו, בן חמישים וארבעה"
            },
            {
              "t": 216.0,
              "text": "מישהו זייף."
            }
          ]
